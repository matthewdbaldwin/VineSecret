# Resend API key — get one free at https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Verified sender address in your Resend account
# For testing you can use: onboarding@resend.dev (sends only to your Resend account email)
EMAIL_FROM=orders@yourdomain.com

# Port for the Express API server (Vite proxies /api here)
SERVER_PORT=3001
