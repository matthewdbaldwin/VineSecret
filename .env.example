# ── Email (SMTP) ─────────────────────────────────────────────────────────────

# Sender address shown in the From field
EMAIL_FROM=orders@vinesecret.com

# SMTP server credentials
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=orders@vinesecret.com
SMTP_PASS=your_smtp_password_here

# Set to "true" only if your provider requires implicit TLS (port 465).
# Leave unset or "false" for STARTTLS (port 587, the common default).
SMTP_SECURE=false

# ── Server ────────────────────────────────────────────────────────────────────

# Port the Express server listens on.
# Dev/preview: keep at 3001 (Vite proxies /api here from port 3000).
# Production (npm run serve): set to 3000 (or 80/443) — Express serves
# both the API and the built React app from a single port.
SERVER_PORT=3001

# Origin allowed by CORS. In production set this to your actual domain,
# e.g. https://vinesecret.com — only that origin can call the API.
ALLOWED_ORIGIN=http://localhost:3000
