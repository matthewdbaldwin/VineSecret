# ── Email (Resend) ────────────────────────────────────────────────────────────

# Resend API key — get yours at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Sender address shown in the From field (must be a verified domain in Resend)
EMAIL_FROM=orders@vinesecret.com

# ── Server ────────────────────────────────────────────────────────────────────

# Port the Express server listens on.
# Dev/preview: keep at 3001 (Vite proxies /api here from port 3000).
# Production (npm run serve): set to 3000 (or 80/443) — Express serves
# both the API and the built React app from a single port.
SERVER_PORT=3001

# Origin allowed by CORS. In production set this to your actual domain,
# e.g. https://vinesecret.com — only that origin can call the API.
ALLOWED_ORIGIN=http://localhost:3000

# ── Stripe (payments) ─────────────────────────────────────────────────────────

# Server-side secret key — keep this private, never expose to the browser.
# Get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here

# Client-side publishable key — safe to expose (prefixed VITE_ so Vite inlines it).
VITE_STRIPE_PUBLIC_KEY=pk_test_your_key_here

# ── Social / SEO ───────────────────────────────────────────────────────────────

# Public-facing root URL used in Open Graph tags served to social crawlers.
# Must be an absolute URL with no trailing slash.
SITE_URL=https://vinesecret.com
