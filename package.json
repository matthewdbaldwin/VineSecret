{
  "name": "vinesecret",
  "version": "2.2.0",
  "description": "Starting setup for react redux project",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"vite --host 0.0.0.0 --port 3000\" \"node server/index.js\"",
    "start:server": "node server/index.js",
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node -e \"const fs=require('fs');const path=require('path');const src=path.join('dist','index.html');const dest=path.join('dist','404.html');fs.copyFileSync(src,dest);\"",
    "serve": "npm run build && node server/index.js",
    "preview": "concurrently \"vite preview --host 0.0.0.0 --port 3000\" \"node server/index.js\"",
    "install:noproxy": "env -u http_proxy -u https_proxy -u HTTP_PROXY -u HTTPS_PROXY -u npm_config_http_proxy -u npm_config_https_proxy npm install",
    "lint": "eslint src --ext .js,.jsx",
    "test": "node -e \"console.log('No automated tests are defined yet.');\""
  },
  "author": "Matthew Baldwin",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matthewdbaldwin/VineSecret.git"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@stripe/react-stripe-js": "^6.0.0",
    "@stripe/stripe-js": "^9.0.0",
    "axios": "^1.13.5",
    "bootstrap": "^5.3.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jquery": "^3.7.1",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.9",
    "react-dom": "^18.3.1",
    "react-redux": "^7.2.9",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4",
    "reactstrap": "^9.2.2",
    "redux": "^4.2.1",
    "redux-form": "^8.3.10",
    "resend": "^6.9.3",
    "stripe": "^21.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.21.0",
    "vite": "^7.3.2"
  },
  "bugs": {
    "url": "https://github.com/matthewdbaldwin/VineSecret/issues"
  },
  "homepage": "https://github.com/matthewdbaldwin/VineSecret#readme"
}
